{
  "info": {
    "name": "JobTrackr API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /users/ – Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "POST /token – Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/token",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "test@example.com" },
                { "key": "password", "value": "password123" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Job Sources",
      "item": [
        {
          "name": "POST /sources/ – Create source",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sources/",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/jobs\",\n  \"name\": \"Example Jobs\",\n  \"check_frequency\": \"daily\"\n}"
            }
          }
        },
        {
          "name": "GET /sources/ – List sources",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sources/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "DELETE /sources/:id – Delete source",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/sources/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "POST /sources/:id/scrape – Trigger scrape",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sources/1/scrape",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "GET /jobs/ – List all jobs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /jobs/?new_only=true – New jobs only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs/?new_only=true",
              "query": [{ "key": "new_only", "value": "true" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /jobs/?source_id=1 – Jobs by source",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/jobs/?source_id=1",
              "query": [{ "key": "source_id", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /jobs/:id – Get job",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "PATCH /jobs/:id/read – Mark as read",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/jobs/1/read",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /admin/sources/ – All sources",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/sources/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /admin/jobs/ – All jobs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/jobs/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
